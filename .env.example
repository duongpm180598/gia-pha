# -----------------------------------------------------------------------------
# MẪU BIẾN MÔI TRƯỜNG CẤU HÌNH (ENVIRONMENT VARIABLES)
# -----------------------------------------------------------------------------
# Hướng dẫn:
# 1. Chép (copy) file này thành ".env.local"
# 2. Điền các giá trị thực tế tương ứng với dự án Supabase của bạn

# Tên của ứng dụng web được hiển thị cho người dùng
SITE_NAME="Phạm Gia"

# URL của project Supabase (Lấy từ Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Khóa Public (Lấy từ Settings > API > Project API keys > anon / public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"

# Khóa Service Role (Lấy từ Settings > API > Project API keys > service_role)
# CHỈ dùng ở server (cron job đọc toàn bộ persons/subscriptions bất chấp RLS) — KHÔNG lộ ra client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cặp khóa VAPID cho Web Push (sinh bằng lệnh: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:you@example.com"

# Chuỗi bí mật để xác thực request từ Supabase pg_cron gọi tới /api/cron/notify-events
CRON_SECRET="generate-a-random-secret-string"
